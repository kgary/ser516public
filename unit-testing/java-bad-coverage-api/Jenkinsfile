pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                dir('unit-testing/java-bad-coverage-api') {
                    sh 'mvn clean compile'
                }
            }
        }

        stage('Test') {
            steps {
                dir('unit-testing/java-bad-coverage-api') {
                    sh 'mvn verify'
                }
            }
        }

        stage('SpotBugs Analysis') {
            steps {
                dir('unit-testing/java-bad-coverage-api') {
                    sh 'mvn spotbugs:spotbugs'
                }
            }
        }

        stage('Package') {
            steps {
                dir('unit-testing/java-bad-coverage-api') {
                    sh 'mvn package -DskipTests'
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('unit-testing/java-bad-coverage-api') {
                    sh "docker build -t java-bad-coverage-api:${BUILD_NUMBER} ."
                    sh "docker tag java-bad-coverage-api:${BUILD_NUMBER} java-bad-coverage-api:latest"
                }
            }
        }

        stage('Sanity Check') {
            steps {
                script {
                    // Traefik runs inside DinD and is managed separately by setup-dind-traefik.sh.
                    // This stage only deploys the student container onto traefik-net.
                    // NOTE: This container is intentionally NOT stopped after the pipeline.
                    // To STOP and REMOVE it manually:
                    //   docker stop calc-api && docker rm calc-api

                    // 1. Remove previous calc-api container (if it exists)
                    sh 'docker rm -f calc-api || true'

                    // 2. Start calc-api on traefik-net with Traefik labels (no -p needed)
                    // stripPrefix middleware strips /group0/calculator before forwarding to Spring Boot
                    sh """docker run -d --name calc-api \
                        --network traefik-net \
                        --label 'traefik.enable=true' \
                        --label 'traefik.http.routers.g0-calculator.entrypoints=web' \
                        --label 'traefik.http.routers.g0-calculator.rule=PathPrefix(`/group0/calculator`)' \
                        --label 'traefik.http.routers.g0-calculator.middlewares=strip-g0-calculator' \
                        --label 'traefik.http.middlewares.strip-g0-calculator.stripprefix.prefixes=/group0/calculator' \
                        --label 'traefik.http.services.g0-calculator.loadbalancer.server.port=8080' \
                        java-bad-coverage-api:${BUILD_NUMBER}"""

                    // 3. Wait for Traefik to discover calc-api (Docker event propagation ~2-3s)
                    sh 'sleep 5'

                    // 4. SanityCheck calls Traefik via its DinD-internal DNS name
                    sh 'chmod +x unit-testing/java-bad-coverage-api/SanityCheck.sh'
                    sh 'unit-testing/java-bad-coverage-api/SanityCheck.sh'

                    echo 'Sanity check passed — calc-api accessible at https://swenv0linux.asu.edu/group0/calculator/api/calculator/calculate'
                }
            }
        }

        stage('Postman Tests') {
            steps {
                script {
                    // Run Newman via Docker — no Node.js/npx required on the agent
                    sh """
                        docker run --rm \
                            --network traefik-net \
                            -v "\${WORKSPACE}:/workspace" \
                            -w /workspace \
                            postman/newman:alpine \
                            run unit-testing/java-bad-coverage-api/postman/newman-jenkins-collection.postman_collection.json \
                            -e unit-testing/java-bad-coverage-api/postman/newman-jenkins-environment.postman_environment.json \
                            --env-var "base_url=http://traefik:80/group0/calculator" \
                            --reporters cli,htmlextra \
                            --reporter-htmlextra-export unit-testing/java-bad-coverage-api/target/newman-report.html
                    """
                }
            }
        }

        stage('Cleanup') {
            steps {
                // Remove the Docker IMAGE only. The container stays alive.
                sh "docker rmi java-bad-coverage-api:${BUILD_NUMBER} java-bad-coverage-api:latest || true"
            }
        }
    }

    post {
        always {
            // Publish JUnit test results
            junit '**/target/surefire-reports/*.xml'

            // Publish JaCoCo code coverage
            recordCoverage(tools: [[parser: 'JACOCO',
                pattern: 'unit-testing/java-bad-coverage-api/target/site/jacoco/jacoco.xml']])

            // Archive Newman HTML report
            archiveArtifacts artifacts: '**/target/newman-report.html', allowEmptyArchive: true

            // Archive SpotBugs HTML report
            archiveArtifacts artifacts: '**/target/spotbugs.html', allowEmptyArchive: true

            // Archive built JAR
            archiveArtifacts artifacts: '**/target/*.jar', allowEmptyArchive: true
        }

        success {
            echo '''
Build succeeded!
 ─────────────────────────────────────────────────────
 calc-api is running and routed via Traefik.
 Public URL: https://swenv0linux.asu.edu/group0/calculator/api/calculator/calculate
 To remove it manually:
   docker stop calc-api && docker rm calc-api
 ─────────────────────────────────────────────────────
'''
        }

        failure {
            echo 'Build failed!'
        }
    }
}
