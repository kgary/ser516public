pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                dir ('unit-testing/java-good-coverage') {
                    sh 'mvn clean compile'
                }
            }
        }

        stage('Test') {
            steps {
                dir ('unit-testing/java-good-coverage') {
                    sh 'mvn test'
                }
            }
        }

        stage('Code Coverage') {
            steps {
                dir ('unit-testing/java-good-coverage') {
                    sh 'mvn jacoco:report'
                }
            }
        }

        stage('SpotBugs Analysis') {
            steps {
                dir ('unit-testing/java-good-coverage') {
                    sh 'mvn spotbugs:spotbugs'
                }
            }
        }

        stage('Package') {
            steps {
                dir ('unit-testing/java-good-coverage') {
                    sh 'mvn package -DskipTests'
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('unit-testing/java-good-coverage') {
                    sh "docker build -t java-good-coverage:${BUILD_NUMBER} ."
                    sh "docker tag java-good-coverage:${BUILD_NUMBER} java-good-coverage:latest"
                }
            }
        }

        stage('Sanity Check') {
            steps {
                script {
                    def output = sh(
                        script: "docker run --rm java-good-coverage:${BUILD_NUMBER}",
                        returnStdout: true
                    ).trim()
                    echo "Container output: ${output}"
                    if (!output.contains('Result: 5')) {
                        error "Sanity check failed! Expected 'Result: 5' but got: ${output}"
                    }
                    echo 'Sanity check passed — container is working as intended.'
                }
            }
        }

        stage('Cleanup') {
            steps {
                sh "docker rmi java-good-coverage:${BUILD_NUMBER} java-good-coverage:latest || true"
            }
        }
    }

    post {
        always {
            // Publish test results
            junit '**/target/surefire-reports/*.xml'
            
            // Publish code coverage
            recordCoverage(tools: [[parser: 'JACOCO', pattern: 'unit-testing/java-good-coverage/target/site/jacoco/jacoco.xml']])
            
            // Archive SpotBugs HTML report
            archiveArtifacts artifacts: '**/target/spotbugs.html', allowEmptyArchive: true
            
            // Archive JAR artifacts
            archiveArtifacts artifacts: '**/target/*.jar', allowEmptyArchive: true
        }

        success {
            echo 'Build succeeded!'
        }

        failure {
            echo 'Build failed!'
        }
    }
}
