pipeline {
    agent none
    
    stages {
        stage('Checkout') {
            agent any
            steps {
                checkout scm
            }
        }
        
        stage('Install Dependencies') {
            agent {
                docker {
                    image 'python:3'
                    args '-u root'
                }
            }
            steps {
                dir('unit-testing/python-good-coverage') {
                    sh '''
                        pip3 install poetry==1.6.1
                        poetry config virtualenvs.in-project true
                        poetry install --no-interaction --no-ansi
                    '''
                }
            }
        }
        
        stage('Test') {
            agent {
                docker {
                    image 'python:3'
                    args '-u root'
                }
            }
            steps {
                dir('unit-testing/python-good-coverage') {
                    sh '''
                        pip3 install poetry==1.6.1
                        poetry config virtualenvs.in-project true
                        poetry install --no-interaction --no-ansi
                        poetry run pytest --verbose \
                            --cov=src/calculator \
                            --cov-report=html:htmlcov \
                            --cov-report=xml:coverage.xml \
                            --cov-report=term-missing \
                            --cov-fail-under=90 \
                            --junitxml=test-results.xml
                    '''
                }
            }
        }
        
        stage('BDD Tests') {
            agent {
                docker {
                    image 'python:3'
                    args '-u root'
                }
            }
            steps {
                dir('unit-testing/python-good-coverage') {
                    sh '''
                        pip3 install poetry==1.6.1
                        poetry config virtualenvs.in-project true
                        poetry install --no-interaction --no-ansi
                        poetry run behave --format=pretty
                    '''
                }
            }
        }
        
        stage('Pylint Analysis') {
            agent {
                docker {
                    image 'python:3'
                    args '-u root'
                }
            }
            steps {
                dir('unit-testing/python-good-coverage') {
                    sh '''
                        pip3 install poetry==1.6.1
                        poetry config virtualenvs.in-project true
                        poetry install --no-interaction --no-ansi
                        poetry run pylint src/calculator --output-format=parseable --reports=yes > pylint-report.txt || true
                    '''
                }
            }
        }

        stage('Docker Build') {
            agent any
            steps {
                dir('unit-testing/python-good-coverage') {
                    sh "docker build -t python-good-coverage:${BUILD_NUMBER} ."
                    sh "docker tag python-good-coverage:${BUILD_NUMBER} python-good-coverage:latest"
                }
            }
        }

        stage('Sanity Check') {
            agent any
            steps {
                script {
                    def output = sh(
                        script: "docker run --rm python-good-coverage:${BUILD_NUMBER}",
                        returnStdout: true
                    ).trim()
                    echo "Container output: ${output}"
                    if (!output.contains('Result: 5')) {
                        error "Sanity check failed! Expected 'Result: 5' but got: ${output}"
                    }
                    echo 'Sanity check passed — container is working as intended.'
                }
            }
        }

        stage('Cleanup') {
            agent any
            steps {
                sh "docker rmi python-good-coverage:${BUILD_NUMBER} python-good-coverage:latest || true"
            }
        }
    }
    
    post {
        always {
            node('built-in') {
                junit allowEmptyResults: true, testResults: 'unit-testing/python-good-coverage/test-results.xml'
                
                publishHTML([
                    allowMissing: true,
                    alwaysLinkToLastBuild: true,
                    keepAll: true,
                    reportDir: 'unit-testing/python-good-coverage/htmlcov',
                    reportFiles: 'index.html',
                    reportName: 'Coverage Report'
                ])
                
                archiveArtifacts artifacts: 'unit-testing/python-good-coverage/coverage.xml,unit-testing/python-good-coverage/pylint-report.txt', allowEmptyArchive: true
            }
        }
        
        success {
            echo 'Build succeeded!'
        }
        
        failure {
            echo 'Build failed!'
        }
    }
}
